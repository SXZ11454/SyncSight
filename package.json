{
  "name": "syncsight",
  "version": "1.0.0",
  "description": "基于 Electron 的屏幕共享应用",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "app:dir": "electron-builder --dir",
    "app:dist": "electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "author": "SyncSight",
