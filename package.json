{
  "name": "syncsight",
  "version": "1.1.2",
  "description": "基于 Electron 的屏幕共享应用",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "SyncSight",
  "license": "MIT",
  "build": {
    "appId": "com.syncsight.app",
    "productName": "SyncSight",
    "files": [
      "src/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "zip", "arch": ["x64", "ia32", "arm64"] }
      ],
      "artifactName": "SyncSight-${version}-win-${arch}-${ext}",
      "publish": {
        "provider": "github",
        "owner": "SXZ11454",
        "repo": "SyncSight"
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerLanguages": ["zh-CN", "en-US"],
      "language": "2052",
      "unicode": true
    },
    "mac": {
      "target": ["zip", "dmg"],
      "artifactName": "SyncSight-${version}-mac-${arch}.${ext}"
    },
    "linux": {
      "target": ["deb", "rpm", "zip"],
      "artifactName": "SyncSight-${version}-linux-${arch}.${ext}",
      "category": "Utility"
    }
  },
  "devDependencies": {
    "electron": "^41.4.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "body-parser": "^2.2.2",
    "express": "^5.2.1",
    "router": "^2.2.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  }
}
