    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "body-parser": "^2.2.2",
    "express": "^5.2.1",
    "router": "^2.2.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  }
}
